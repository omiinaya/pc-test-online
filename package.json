{
  "name": "mmit-testing-app",
  "version": "1.0.0",
  "description": "Computer repair testing application",
  "main": "backend/src/server.js",
  "author": "OmarM",
  "engines": {
    "node": "22"
  },
  "scripts": {
    "dev": "node scripts/kill-ports.js 3000 5173 && concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && npm run dev",
    "kill-ports": "node scripts/kill-ports.js 3000 5173",
    "build": "npm run build:frontend && npm run build:backend",
    "build:frontend": "cd frontend && npm run build",
    "build:backend": "cd backend && npm run build",
    "install:all": "npm install && cd frontend && npm install && cd ../backend && npm install",
    "postinstall": "cd frontend && npm install && cd ../backend && npm install",
    "start": "concurrently \"npm run start:backend\" \"npm run start:frontend\"",
    "start:frontend": "cd frontend && npm start",
    "start:backend": "cd backend && npm start",
    "lint": "npm run lint:root && npm run lint:frontend && npm run lint:backend",
    "lint:root": "eslint . --ext .js,.cjs,.mjs --ignore-path .gitignore --ignore-pattern \"frontend/docs/**\" --ignore-pattern \"**/docs/**\"",
    "lint:frontend": "cd frontend && npm run lint",
    "lint:backend": "cd backend && npm run lint",
    "lint:fix": "npm run lint:fix:root && npm run lint:fix:frontend && npm run lint:fix:backend",
    "lint:fix:root": "eslint . --ext .js,.cjs,.mjs --fix --ignore-path .gitignore --ignore-pattern \"frontend/docs/**\" --ignore-pattern \"**/docs/**\"",
    "lint:fix:frontend": "cd frontend && npm run lint",
    "lint:fix:backend": "cd backend && npm run lint:fix",
    "format": "npm run format:root && npm run format:frontend && npm run format:backend",
    "format:root": "prettier --write \"**/*.{js,cjs,mjs,json,md}\" --ignore-path .gitignore",
    "format:frontend": "cd frontend && npm run format",
    "format:backend": "cd backend && npm run format"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^7.2.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "pino": "^10.3.1",
    "vite": "^8.0.1"
  },
  "lint-staged": {
    "*.{js,cjs,mjs}": [
      "eslint --fix"
    ],
    "*.{ts,tsx,vue}": [
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  }
}
